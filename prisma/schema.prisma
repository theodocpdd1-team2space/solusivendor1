model FreeRegistration {
  id              String   @id @default(cuid())
  ownerName       String
  businessName    String
  whatsapp        String
  city            String
  vendorType      String
  instagram       String?
  currentProblem  String?
  goal            String
  packageInterest String   @default("Free Vendor Hoki")
  notes           String?
  source          String   @default("solusivendor.com/free-register")
  status          String   @default("NEW")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([whatsapp])
  @@index([status])
  @@index([createdAt])
}